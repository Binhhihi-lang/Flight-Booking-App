<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6F9">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbarInfoProfile"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/white"
            app:layout_anchor="@+id/appBarLayout"
            app:layout_anchorGravity="center"
            android:layout_marginTop="@dimen/spacing_large"
            app:navigationIcon="@drawable/ic_back"
            app:navigationIconTint="@color/textTitle"
            app:title="Thông tin tài khoản"
            app:titleCentered="true"
            app:titleTextColor="@color/textTitle">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/imgSmallAvatar"
                android:layout_width="35dp"
                android:layout_height="35dp"
                android:layout_gravity="end"
                android:layout_marginEnd="16dp"
                android:background="@color/white"
                android:padding="2dp"
                android:src="@drawable/avatar"
                app:shapeAppearanceOverlay="@style/CircleImage"
                app:strokeColor="#BDBDBD"
                app:strokeWidth="1dp" />
        </com.google.android.material.appbar.MaterialToolbar>

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="80dp">

            <View
                android:id="@+id/viewHeader"
                android:layout_width="match_parent"
                android:layout_height="240dp"
                android:background="#0175F3"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/imgAvatar"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_marginTop="40dp"
                android:padding="4dp"
                android:src="@drawable/avatar"
                app:strokeColor="@color/white"
                app:strokeWidth="2dp"
                app:shapeAppearanceOverlay="@style/CircleImage"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <TextView
                android:id="@+id/tvRoleTag"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Người dùng"
                android:textColor="@color/textTitle"
                android:textSize="14sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/imgAvatar" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardPersonalInfo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp"
                app:layout_constraintTop_toBottomOf="@id/tvRoleTag"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="THÔNG TIN CÁ NHÂN"
                            android:textColor="#0175F3"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:layout_centerVertical="true"/>

                        <ImageView
                            android:id="@+id/btnEditProfile"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_profile_edit"
                            app:tint="#0175F3"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"/>
                    </RelativeLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Họ và tên"
                        android:textSize="13sp"
                        android:layout_marginBottom="6dp"
                        android:textColor="#757575" />

                    <TextView
                        android:id="@+id/tvNameDisplay"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:text="Nguyễn Xuân Ly"
                        android:textColor="@color/text_title"
                        android:textSize="15sp"
                        android:drawableStart="@drawable/ic_profile_card"
                        android:drawablePadding="12dp"
                        app:drawableTint="#0175F3" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Email"
                        android:layout_marginTop="14dp"
                        android:layout_marginBottom="6dp"
                        android:textColor="#757575" />

                    <TextView
                        android:id="@+id/tvEmailDisplay"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:text="nguyenxuanly@gmail.com"
                        android:textColor="#212121"
                        android:textSize="15sp"
                        android:drawableStart="@drawable/ic_profile_email"
                        android:drawablePadding="12dp"
                        app:drawableTint="#0175F3" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Số điện thoại"
                        android:layout_marginTop="14dp"
                        android:layout_marginBottom="6dp"
                        android:textColor="#757575" />

                    <TextView
                        android:id="@+id/tvPhoneDisplay"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:text="+84 987 654 321"
                        android:textColor="#212121"
                        android:textSize="15sp"
                        android:drawableStart="@drawable/ic_profile_phone"
                        android:drawablePadding="12dp"
                        app:drawableTint="#0175F3" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardSystemConfig"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp"
                app:layout_constraintTop_toBottomOf="@id/cardPersonalInfo"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingTop="16dp"
                    android:paddingBottom="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="20dp"
                        android:layout_marginBottom="8dp"
                        android:text="CẤU HÌNH HỆ THỐNG"
                        android:textColor="#0175F3"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/btnChangePassword"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:gravity="center_vertical"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:text="Đổi mật khẩu"
                        android:textColor="#212121"
                        android:textSize="15sp"
                        android:background="?attr/selectableItemBackground"
                        app:drawableStartCompat="@drawable/ic_menu_password"
                        app:drawableEndCompat="@drawable/ic_chevron_right"
                        app:drawableTint="#0175F3"
                        android:drawablePadding="16dp" />

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0" android:layout_marginStart="60dp" android:layout_marginEnd="20dp"/>

                    <TextView
                        android:id="@+id/btnPolicy"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:gravity="center_vertical"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:text="Chính sách &amp; Điều khoản"
                        android:textColor="#212121"
                        android:textSize="15sp"
                        android:background="?attr/selectableItemBackground"
                        app:drawableStartCompat="@drawable/ic_menu_policy"
                        app:drawableEndCompat="@drawable/ic_chevron_right"
                        app:drawableTint="#0175F3"
                        android:drawablePadding="16dp" />

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0" android:layout_marginStart="60dp" android:layout_marginEnd="20dp"/>

                    <TextView
                        android:id="@+id/btnSupport"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:gravity="center_vertical"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:text="Trung tâm trợ giúp"
                        android:textColor="#212121"
                        android:textSize="15sp"
                        android:background="?attr/selectableItemBackground"
                        app:drawableStartCompat="@drawable/ic_menu_support"
                        app:drawableEndCompat="@drawable/ic_chevron_right"
                        app:drawableTint="#0175F3"
                        android:drawablePadding="16dp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#F0F0F0"
                        android:layout_marginStart="60dp"
                        android:layout_marginEnd="20dp"/>

                    <TextView
                        android:id="@+id/btnLanguage"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:gravity="center_vertical"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:text="Ngôn ngữ"
                        android:textColor="#212121"
                        android:textSize="15sp"
                        android:background="?attr/selectableItemBackground"
                        app:drawableStartCompat="@drawable/ic_menu_language"
                        app:drawableEndCompat="@drawable/ic_chevron_right"
                        app:drawableTint="#0175F3"
                        android:drawablePadding="16dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogout"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_margin="16dp"
                android:text="Đăng xuất"
                android:textColor="#D32F2F"
                android:textSize="16sp"
                app:strokeColor="#D32F2F"
                app:icon="@drawable/ic_menu_logout"
                app:iconTint="#D32F2F"
                app:iconGravity="textStart"
                app:layout_constraintTop_toBottomOf="@id/cardSystemConfig"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.core.widget.NestedScrollView>



</androidx.coordinatorlayout.widget.CoordinatorLayout>