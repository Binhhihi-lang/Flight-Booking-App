<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_screen"
    tools:context=".ui.view.fragment.HomeFragment">

    <ImageView
        android:id="@+id/iv_bg_header"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        android:background="@color/primary_blue"
        android:src="@drawable/world"
        app:layout_constraintHeight_percent="0.35"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tv_header_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_large"
        android:text="Đặt Vé Máy Bay"
        android:textColor="@color/white"
        android:textSize="@dimen/text_size_main"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/imgSmallAvatar"
        android:layout_width="45dp"
        android:layout_height="45dp"
        android:layout_gravity="end"
        android:layout_marginEnd="16dp"
        android:background="@color/white"
        android:padding="2dp"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_nav_profile"
        app:layout_constraintBottom_toBottomOf="@id/tv_header_title"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tv_header_title"
        app:shapeAppearanceOverlay="@style/CircleImage"
        app:strokeColor="#BDBDBD"
        app:strokeWidth="1dp" />


    <LinearLayout
        android:id="@+id/layout_tabs"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="24dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/tv_header_title">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_one_way"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:backgroundTint="@color/blue_primary"
            android:text="MỘT CHIỀU"
            android:textAllCaps="false"
            android:textColor="@color/bg_card_white"
            app:cornerRadius="24dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_round"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:backgroundTint="@color/white"
            android:text="KHỨ HỒI"
            android:textAllCaps="false"
            android:textColor="@color/blue_primary"
            app:cornerRadius="24dp"
            app:elevation="0dp" />
    </LinearLayout>
    <!--Đổ bóng cardElevation    -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_flight_form"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="15dp"
        android:layout_marginTop="24dp"
        app:cardBackgroundColor="@color/bg_card_white"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp"
        app:layout_constraintTop_toBottomOf="@id/layout_tabs">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_from"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:layout_constraintTop_toTopOf="parent"
                app:strokeColor="@color/stroke_light_grey"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="16dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_flight_takeoff"
                        app:tint="@color/text_main_dark" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Hà Nội "
                                android:textColor="@color/text_main_dark"
                                android:textSize="18sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:text="HAN"
                                android:textColor="@color/text_sub_grey"
                                android:textSize="14sp" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Nội Bài"
                            android:textColor="@color/text_hint_light"
                            android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tv_label_from"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:background="@color/bg_card_white"
                android:paddingHorizontal="4dp"
                android:text="Khởi hành từ"
                android:textColor="@color/text_sub_grey"
                android:textSize="12sp"

                app:layout_constraintBottom_toTopOf="@+id/card_from"
                app:layout_constraintStart_toStartOf="@+id/card_from"
                app:layout_constraintTop_toTopOf="@+id/card_from" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_to"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:layout_constraintTop_toBottomOf="@id/card_from"
                app:strokeColor="@color/stroke_light_grey"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="16dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_flight_land"
                        app:tint="@color/text_main_dark" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="TP.Hồ Chí Minh"
                                android:textColor="@color/text_main_dark"
                                android:textSize="18sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:text="SGN"
                                android:textColor="@color/text_sub_grey"
                                android:textSize="14sp" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Tân Sân Nhất"
                            android:textColor="@color/text_hint_light"
                            android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tv_label_to"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:background="@color/bg_card_white"
                android:paddingHorizontal="4dp"
                android:text="Đến"
                android:textColor="@color/text_sub_grey"
                android:textSize="12sp"

                app:layout_constraintBottom_toTopOf="@+id/card_to"
                app:layout_constraintStart_toStartOf="@+id/card_to"
                app:layout_constraintTop_toTopOf="@+id/card_to" />

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fab_swap"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="24dp"

                app:backgroundTint="@color/bg_card_white"

                app:elevation="4dp"

                app:layout_constraintBottom_toTopOf="@id/card_to"
                app:layout_constraintEnd_toEndOf="parent"

                app:layout_constraintTop_toBottomOf="@id/card_from"

                app:maxImageSize="30dp"
                app:pressedTranslationZ="8dp"
                app:srcCompat="@drawable/ic_swap_vertical" />


            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/layout_row_dates"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:layout_constraintTop_toBottomOf="@+id/card_to">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/container_departure"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    app:layout_constraintEnd_toStartOf="@+id/container_return"
                    app:layout_constraintHorizontal_weight="1"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_departure"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:layout_marginTop="8dp"
                        app:cardBackgroundColor="@android:color/transparent"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:strokeColor="@color/stroke_light_grey"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="12dp">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_calendar"
                                app:tint="@color/text_main_dark" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="10dp"
                                android:text="15/07/2022"
                                android:textColor="@color/text_main_dark"
                                android:textSize="15sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:background="@color/bg_card_white"
                        android:paddingHorizontal="4dp"
                        android:text="Ngày đi"
                        android:textColor="@color/text_sub_grey"
                        android:textSize="12sp"
                        app:layout_constraintBottom_toTopOf="@id/card_departure"
                        app:layout_constraintStart_toStartOf="@id/card_departure"
                        app:layout_constraintTop_toTopOf="@id/card_departure" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/container_return"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_weight="1"
                    app:layout_constraintStart_toEndOf="@id/container_departure"
                    app:layout_constraintTop_toTopOf="parent">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_return"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:layout_marginTop="8dp"
                        app:cardBackgroundColor="@android:color/transparent"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:strokeColor="@color/stroke_light_grey"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="12dp">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_calendar"
                                app:tint="@color/text_main_dark" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="10dp"
                                android:text="15/07/2022"
                                android:textColor="@color/text_main_dark"
                                android:textSize="15sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:background="@color/bg_card_white"
                        android:paddingHorizontal="4dp"
                        android:text="Ngày về"
                        android:textColor="@color/text_sub_grey"
                        android:textSize="12sp"
                        app:layout_constraintBottom_toTopOf="@id/card_return"
                        app:layout_constraintStart_toStartOf="@id/card_return"
                        app:layout_constraintTop_toTopOf="@id/card_return" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>


            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/layout_row_info"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:layout_constraintTop_toBottomOf="@+id/layout_row_dates">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/container_traveller"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_traveller"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:layout_marginTop="8dp"
                        app:cardBackgroundColor="@android:color/transparent"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:strokeColor="#E0E0E0"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="horizontal"
                            android:weightSum="3"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="16dp">

                            <TextView
                                android:id="@+id/tv_adult_count"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="1 Người lớn"
                                android:textColor="#212121"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:gravity="start" />

                            <View
                                android:layout_width="2dp"
                                android:layout_height="28dp"
                                android:background="#E0E0E0" />
                            <TextView
                                android:id="@+id/tv_child_count"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="0 Trẻ em"
                                android:textColor="#212121"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:gravity="center" />
                            <View
                                android:layout_width="2dp"
                                android:layout_height="28dp"
                                android:background="#E0E0E0" />

                            <TextView
                                android:id="@+id/tv_infant_count"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="0 Em bé"
                                android:textColor="#212121"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:gravity="center" />

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:background="#FFFFFF"
                        android:paddingHorizontal="4dp"
                        android:text="Traveller"
                        android:textColor="#757575"
                        android:textSize="12sp"
                        app:layout_constraintBottom_toTopOf="@id/card_traveller"
                        app:layout_constraintStart_toStartOf="@id/card_traveller"
                        app:layout_constraintTop_toTopOf="@id/card_traveller" />

                </androidx.constraintlayout.widget.ConstraintLayout>

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/container_class"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/container_traveller">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_class"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:layout_marginTop="8dp"
                        app:cardBackgroundColor="@android:color/transparent"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:strokeColor="@color/stroke_light_grey"
                        app:strokeWidth="1dp">

                        <TextView
                            android:id="@+id/tv_seat_class_summary"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="16dp"
                            android:text="Phổ thông"
                            android:textColor="@color/text_main_dark"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:background="@color/bg_card_white"
                        android:paddingHorizontal="4dp"
                        android:text="Hạng ghế"
                        android:textColor="@color/text_sub_grey"
                        android:textSize="12sp"
                        app:layout_constraintBottom_toTopOf="@id/card_class"
                        app:layout_constraintStart_toStartOf="@id/card_class"
                        app:layout_constraintTop_toTopOf="@id/card_class" />
                </androidx.constraintlayout.widget.ConstraintLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>


            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_search_flights"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/btn_search_selector"
                android:text="Search"
                android:textAllCaps="false"
                android:textSize="18sp"
                app:backgroundTint="@null"
                app:cornerRadius="12dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintTop_toBottomOf="@id/layout_row_info" />


        </androidx.constraintlayout.widget.ConstraintLayout>


    </com.google.android.material.card.MaterialCardView>


</androidx.constraintlayout.widget.ConstraintLayout>