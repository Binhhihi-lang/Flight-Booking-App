<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/bg_light_gray"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Chọn Hạng Ghế"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#212121"
        android:layout_marginBottom="16dp"
        android:gravity="center"/>

    <RadioGroup
        android:id="@+id/rg_seat_class"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <RadioButton
            android:id="@+id/rb_economy"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Phổ thông (Economy)"
            android:textSize="16sp"
            android:paddingVertical="12dp"
            android:checked="true"/>

        <RadioButton
            android:id="@+id/rb_premium_economy"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Phổ thông đặc biệt (Premium Economy)"
            android:textSize="16sp"
            android:paddingVertical="12dp"/>

        <RadioButton
            android:id="@+id/rb_business"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Thương gia (Business)"
            android:textSize="16sp"
            android:paddingVertical="12dp"/>

        <RadioButton
            android:id="@+id/rb_first_class"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Hạng nhất (First Class)"
            android:textSize="16sp"
            android:paddingVertical="12dp"/>
    </RadioGroup>

</LinearLayout>