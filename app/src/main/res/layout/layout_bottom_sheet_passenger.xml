<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/bg_light_gray"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Chọn hành khách"
        android:textColor="@color/text_sub_grey"
        android:textSize="16sp"
        android:layout_marginBottom="16dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp"
        android:background="@color/bg_card_white"
        android:padding="8dp">

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@color/blue_primary"
            android:padding="8dp"
            app:tint="@color/white"
            android:src="@drawable/ic_nav_profile" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Người Lớn"
                android:textColor="@color/text_main_dark"
                android:textSize="16sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="> 12 tuổi"
                android:textSize="12sp" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/btn_minus_adult"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@color/blue_primary"
            android:src="@drawable/ic_minus"
            app:tint="@color/white"/>

        <TextView
            android:id="@+id/tv_count_adult"
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:text="1"
            android:textAlignment="center"
            android:textSize="18sp"
            android:textColor="@color/text_main_dark"/>

        <ImageButton
            android:id="@+id/btn_plus_adult"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@color/blue_primary"
            android:src="@drawable/ic_plus"
            app:tint="@color/white"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp"
        android:background="@color/bg_card_white"
        android:padding="8dp">

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@color/blue_primary"
            android:padding="8dp"
            app:tint="@color/white"
            android:src="@drawable/ic_child"
            />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Trẻ em"
                android:textColor="@color/text_main_dark"
                android:textSize="16sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2 - 12 tuổi"
                android:textSize="12sp" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/btn_minus_child"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@color/blue_primary"
            android:src="@drawable/ic_minus"
            app:tint="@color/white"/>

        <TextView
            android:id="@+id/tv_count_child"
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:text="1"
            android:textAlignment="center"
            android:textSize="18sp"
            android:textColor="@color/text_main_dark"/>

        <ImageButton
            android:id="@+id/btn_plus_child"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@color/blue_primary"
            android:src="@drawable/ic_plus"
            app:tint="@color/white"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp"
        android:background="@color/bg_card_white"
        android:padding="8dp">

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@color/blue_primary"
            android:padding="8dp"
            app:tint="@color/white"
            android:src="@drawable/ic_baby" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Em bé"
                android:textColor="@color/text_main_dark"
                android:textSize="16sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 - 2 tuổi"
                android:textSize="12sp" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/btn_minus_baby"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@color/blue_primary"
            android:src="@drawable/ic_minus"
            app:tint="@color/white"/>

        <TextView
            android:id="@+id/tv_count_baby"
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:text="1"
            android:textAlignment="center"
            android:textSize="18sp"
            android:textColor="@color/text_main_dark"/>

        <ImageButton
            android:id="@+id/btn_plus_baby"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@color/blue_primary"
            android:src="@drawable/ic_plus"
            app:tint="@color/white"/>
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_confirm_passenger"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="16dp"
        android:text="CHỌN"
        android:textSize="16sp"
        app:cornerRadius="8dp"
        android:backgroundTint="@color/blue_primary" />

</LinearLayout>